###############################################################################
# Proyecto Atlas
# Archivo: .gitignore
#
# Descripción:
#     Indica a Git qué archivos y carpetas NO deben incluirse
#     en el repositorio.
#
#     Esto evita subir:
#
#     - Archivos temporales.
#     - Caché de Python.
#     - Entornos virtuales.
#     - Configuración del IDE.
#     - Bases de datos locales.
#     - Registros (logs).
#     - Memorias personales de los usuarios.
#
#     Gracias a ello el repositorio permanece limpio y únicamente
#     contiene el código fuente del proyecto.
###############################################################################


###############################################################################
# CACHÉ DE PYTHON
###############################################################################

__pycache__/
*.pyc
*.pyo
*.pyd


###############################################################################
# VARIABLES DE ENTORNO
###############################################################################

.env
.env.*


###############################################################################
# ENTORNOS VIRTUALES
###############################################################################

venv/
.venv/


###############################################################################
# CONFIGURACIÓN DE LOS EDITORES
###############################################################################

.idea/
.vscode/


###############################################################################
# ARCHIVOS DE LOG
###############################################################################

*.log


###############################################################################
# BASES DE DATOS LOCALES
###############################################################################

*.sqlite3
*.db


###############################################################################
# MEMORIA PERSONAL DE LOS USUARIOS
###############################################################################

memory/data/*.json
memory/data/memories.json


###############################################################################
# ARCHIVOS DEL SISTEMA OPERATIVO
###############################################################################

# Windows
Thumbs.db

# macOS
.DS_Store


###############################################################################
# ARCHIVOS DE PRUEBAS
###############################################################################

.coverage
htmlcov/
.pytest_cache/


###############################################################################
# MODELOS DE IA (FUTURO)
###############################################################################

models/
ollama_models/
*.gguf


###############################################################################
# ARCHIVOS DE RESPALDO DE EDITORES
###############################################################################

*.orig
*.rej


###############################################################################
# BACKUPS
###############################################################################

*.bak
*.old
*.backup


###############################################################################
# ARCHIVOS TEMPORALES
###############################################################################

*.tmp
*.temp


###############################################################################
# CACHÉ DE HERRAMIENTAS DE IA (FUTURO)
###############################################################################

.cache/
.cache/**


###############################################################################
# NOTEBOOKS (SI ALGÚN DÍA SE UTILIZAN)
###############################################################################

.ipynb_checkpoints/