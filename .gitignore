# =============================================================================
# Proyecto Atlas
# Archivo: .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Secretos y configuración privada
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example

*.pem
*.key
*.p12
*.pfx
*.crt
*.cer

credentials.json
client_secret*.json
token.json
tokens.json
secrets.json

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so

.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml

# Entornos virtuales
.venv/
venv/
env/
ENV/

# Empaquetado
build/
dist/
*.egg-info/
.eggs/

# -----------------------------------------------------------------------------
# Editores e IDE
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.code-workspace

# -----------------------------------------------------------------------------
# Sistema operativo
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

# -----------------------------------------------------------------------------
# Logs y temporales
# -----------------------------------------------------------------------------
logs/
*.log

temp/
tmp/
cache/

*.tmp
*.temp
*.bak
*.old
*.part
*.crdownload
*.download

# -----------------------------------------------------------------------------
# Bloqueos, procesos y estados temporales
# -----------------------------------------------------------------------------
*.lock
*.pid

data/integrations/telegram/*.lock
data/integrations/telegram/python_path.txt
data/integrations/telegram/supervisor_status.json

# -----------------------------------------------------------------------------
# Telegram: cuentas, sesiones y datos privados
# -----------------------------------------------------------------------------
data/integrations/telegram/state.json
data/integrations/telegram/pending_messages.json
data/integrations/telegram/quarantine/
data/integrations/telegram/downloads/

# -----------------------------------------------------------------------------
# Datos privados de usuarios
# -----------------------------------------------------------------------------
data/users/

memory/data/memories.json
memory/data/legacy/

# Mantener la estructura de las carpetas vacías
!data/users/.gitkeep
!memory/data/.gitkeep

# -----------------------------------------------------------------------------
# Historiales y datos generados
# -----------------------------------------------------------------------------
**/internet_history.jsonl
data/monitoring/pc_status.json
data/incidents/
data/runtime/
data/sessions/

# -----------------------------------------------------------------------------
# Índices locales, RAG y bases vectoriales
# -----------------------------------------------------------------------------
data/indexes/
data/vector_store/
data/chroma/
data/faiss/

*.db
*.sqlite
*.sqlite3

# -----------------------------------------------------------------------------
# Modelos y archivos grandes descargados
# -----------------------------------------------------------------------------
models/
*.gguf
*.ggml
*.bin

# -----------------------------------------------------------------------------
# Copias de seguridad y paquetes generados
# -----------------------------------------------------------------------------
backups/
releases/
*.zip
*.7z
*.rar
*.tar
*.tar.gz

# -----------------------------------------------------------------------------
# Archivos de prueba locales no destinados al repositorio
# -----------------------------------------------------------------------------
test_output/
test_results/
reports/local/

# -----------------------------------------------------------------------------
# Instaladores y ejecutables
# -----------------------------------------------------------------------------
*.exe
*.msi